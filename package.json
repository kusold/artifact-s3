{
  "name": "@kusold/artifact-s3",
  "version": "1.0.0",
  "description": "Core library for S3-based artifact storage in GitHub Actions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build"
  },
  "keywords": [
    "github",
    "actions",
    "artifact",
    "s3"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/glob": "^0.5.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  }
}
